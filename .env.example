# Crypto Futures Signal Bot – Environment Variables
# Copy this file to .env and edit as needed.

# Comma-separated list of trading pairs to analyse
PAIRS=BTC/USDT,ETH/USDT,SOL/USDT

# Comma-separated list of timeframes to analyse
TIMEFRAMES=15m,1h,4h

# Data source: cryptocompare or coingecko
DATA_SOURCE=cryptocompare

# CryptoCompare API key (optional – increases rate limits)
# CRYPTOCOMPARE_API_KEY=your_api_key_here

# Number of candles to fetch per request
CANDLE_LIMIT=200

# Signal engine thresholds
LONG_THRESHOLD=5
SHORT_THRESHOLD=-5

# Risk/reward ratio (take_profit = stop_loss_distance * ratio)
RISK_REWARD_RATIO=3.0

# How often to run in loop mode (minutes)
RUN_INTERVAL_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=crypto_signal_bot.log

# ---------------------------------------------------------------------------
# Paper Trading
# ---------------------------------------------------------------------------
# Set to true to enable paper trading (forward signals to PaperInvest)
PAPER_TRADING_ENABLED=false

# PaperInvest API credentials (leave blank to use local simulation)
# PAPERINVEST_API_KEY=your_api_key_here
# PAPERINVEST_API_SECRET=your_api_secret_here
# PAPERINVEST_BASE_URL=https://app.paperinvest.io/api/v1

# PaperInvest API retry settings
PAPERINVEST_RETRY_DELAY=2.0
PAPERINVEST_MAX_RETRIES=3
PAPERINVEST_TIMEOUT=10.0

# Starting balance for local simulation (USDT)
PAPER_INITIAL_BALANCE=10000.0

# Default leverage for paper trades
PAPER_DEFAULT_LEVERAGE=5

# Risk management (fraction of portfolio, e.g. 0.01 = 1%)
PAPER_MAX_RISK_PER_TRADE=0.01
PAPER_MAX_OPEN_TRADES=5
PAPER_DAILY_LOSS_LIMIT=0.05

# Minimum signal quality to place a trade
PAPER_MIN_CONFIDENCE=40
PAPER_MIN_SCORE=5

# Storage paths
PAPER_DATA_DIR=data
PAPER_LOG_DIR=logs

# Backtesting date range (YYYY-MM-DD)
BACKTEST_START=2024-01-01
BACKTEST_END=2024-12-31

# ---------------------------------------------------------------------------
# Exchange mode (paper or binance)
# ---------------------------------------------------------------------------
TRADING_MODE=paper

