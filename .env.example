# Crypto Futures Signal Bot – Environment Variables
# Copy this file to .env and edit as needed.

# Comma-separated list of trading pairs to analyse
PAIRS=BTC/USDT,ETH/USDT,SOL/USDT

# Comma-separated list of timeframes to analyse
TIMEFRAMES=15m,1h,4h

# Data source: cryptocompare or coingecko
DATA_SOURCE=cryptocompare

# CryptoCompare API key (optional – increases rate limits)
# CRYPTOCOMPARE_API_KEY=your_api_key_here

# Number of candles to fetch per request
CANDLE_LIMIT=200

# Signal engine thresholds
LONG_THRESHOLD=5
SHORT_THRESHOLD=-5

# Risk/reward ratio (take_profit = stop_loss_distance * ratio)
RISK_REWARD_RATIO=3.0

# How often to run in loop mode (minutes)
RUN_INTERVAL_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=crypto_signal_bot.log
